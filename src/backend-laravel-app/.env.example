STAFFHUB_GOOGLE_CHAT_ADMIN_SPACE_ID=
STAFFHUB_GOOGLE_CHAT_ALL_STAFF_SPACE_ID=
STAFFHUB_GOOGLE_CHAT_MESSAGE_TIMEOUT_SECONDS=10

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

STAFFHUB_COMPANY_NAME="社会福祉法人 誠心福祉会 池上わかばこども園"
STAFFHUB_LOCATION_NAME="池上わかばこども園"
