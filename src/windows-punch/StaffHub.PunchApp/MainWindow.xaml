<Window x:Class="StaffHub.PunchApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="勤怠打刻"
        Height="720"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Foreground="#27344D">
    <Window.Resources>
        <Style x:Key="GradientButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.78" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F7FAFF" Offset="0" />
            <GradientStop Color="#E8EFFF" Offset="0.58" />
            <GradientStop Color="#EEF1FF" Offset="1" />
        </LinearGradientBrush>
    </Window.Background>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,24">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="職員打刻アプリ" FontSize="36" FontWeight="Bold" Foreground="#27344D" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="StartPunchButton" Content="打刻を開始する" Width="150" Height="44" Margin="0,0,12,0" Style="{StaticResource GradientButtonStyle}" Foreground="White">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6F8FE5" Offset="0" />
                            <GradientStop Color="#9DB2FB" Offset="1" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <Border CornerRadius="18" Padding="16,8">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6F8FE5" Offset="0" />
                            <GradientStop Color="#94ABF7" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="{Binding NetworkStatus}" Foreground="White" FontSize="16" FontWeight="SemiBold" />
                </Border>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#DDE6FA" BorderThickness="1" CornerRadius="24" Padding="36" Margin="0,0,20,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentClockText}" FontSize="64" FontWeight="Bold" Foreground="#000000" TextAlignment="Center" Margin="0,0,0,24" />
                    <TextBlock Text="{Binding ResultHeadline}" FontSize="36" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" LineHeight="46" Margin="0,0,0,14" />
                    <TextBlock Text="{Binding ResultDetail}" FontSize="22" Foreground="#7083A0" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,20" />
                    <TextBlock Text="{Binding EmployeeName}" FontSize="34" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,10" />
                    <TextBlock Text="{Binding LastEventType}" FontSize="24" Foreground="#D87790" TextAlignment="Center" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#F9FBFF" BorderBrush="#DDE6FA" BorderThickness="1" CornerRadius="24" Padding="24">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="保守・試験パネル" FontSize="24" FontWeight="Bold" Margin="0,0,0,16" />
                        <TextBlock Text="端末名" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Settings.DeviceName}" Margin="0,0,0,10" />
                        <TextBlock Text="カードリーダー状態" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ReaderStatus}" Margin="0,0,0,10" TextWrapping="Wrap" />
                        <TextBlock Text="直近カードUID" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding LastCardUid}" Margin="0,0,0,10" TextWrapping="Wrap" />
                        <TextBlock Text="未送信件数" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding PendingCount}" Margin="0,0,0,16" FontSize="22" />
                        <TextBlock Text="模擬カードUID" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SimulatedCardUid, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,10" Padding="8" FontSize="15" BorderBrush="#DDE6FA" Background="White" />
                        <Button x:Name="SimulateButton" Content="模擬スキャン" Height="40" Margin="0,0,0,10" Style="{StaticResource GradientButtonStyle}" Foreground="White">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6F8FE5" Offset="0" />
                                    <GradientStop Color="#9DB2FB" Offset="1" />
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                        <Button x:Name="RetryButton" Content="未送信を再送" Height="40" Style="{StaticResource GradientButtonStyle}" Foreground="White">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E9A6C7" Offset="0" />
                                    <GradientStop Color="#F4BFD9" Offset="1" />
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#F9FBFF" BorderBrush="#DDE6FA" BorderThickness="1" CornerRadius="18" Padding="12" Margin="0,14,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="直近10打刻履歴" FontSize="18" FontWeight="Bold" DockPanel.Dock="Left" />
                    <TextBlock Text="RC-S380実機読取・API送信結果" FontSize="14" Foreground="#7083A0" HorizontalAlignment="Right" />
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="時刻" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="職員" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="2" Text="種別" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="3" Text="結果" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="4" Text="状態" FontWeight="SemiBold" />
                </Grid>

                <ItemsControl Grid.Row="2" ItemsSource="{Binding PunchHistory}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDE6FA" BorderThickness="0,1,0,0" Padding="0,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding TimeText}" FontSize="13" />
                                    <TextBlock Grid.Column="1" Text="{Binding EmployeeName}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding EventTypeText}" FontSize="13" />
                                    <TextBlock Grid.Column="3" Text="{Binding ResultText}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="4" Text="{Binding StatusText}" FontSize="13" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Grid.Row="2" Text="まだ打刻履歴はありません" FontSize="14" Foreground="#7083A0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PunchHistory.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
